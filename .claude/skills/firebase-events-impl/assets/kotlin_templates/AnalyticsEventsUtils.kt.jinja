import com.tohsoft.firebase_events.models.AnalyticsEvent
{% if features.iap %}import com.tohsoft.firebase_events.models.IAPEv
{% endif %}{% if features.onboarding %}import com.tohsoft.firebase_events.models.OnboardingStepEv
{% endif %}{% if features.ads %}import com.tohsoft.firebase_events.models.AdRevenueLike
import com.tohsoft.app_event.AdsEventTracker
{% endif %}{% if features.rate_dialog %}import com.tohsoft.app_event.RateDialogEventTracker
{% endif %}{% if features.open_app_from %}import com.tohsoft.app_event.OpenAppFromIntent
