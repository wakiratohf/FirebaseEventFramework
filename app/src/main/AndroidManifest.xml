<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".DemoApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FirebaseEventFramework">

        <!-- AdMob App ID (TEST). Bắt buộc, thiếu sẽ crash khi MobileAds.initialize.
             Thay bằng App ID thật từ AdMob console trước khi release. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.FirebaseEventFramework">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".TaskListActivity"
            android:exported="false"
            android:label="@string/title_tasks"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.FirebaseEventFramework" />
        <activity
            android:name=".TimerActivity"
            android:exported="false"
            android:label="@string/title_timer"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.FirebaseEventFramework" />
        <activity
            android:name=".StatsActivity"
            android:exported="false"
            android:label="@string/title_stats"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.FirebaseEventFramework" />
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.FirebaseEventFramework" />
        <activity
            android:name=".SubscriptionActivity"
            android:exported="false"
            android:label="@string/title_subscription"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.FirebaseEventFramework" />
    </application>

</manifest>